%%{init: {'theme':'base', 'themeVariables': {'fontSize':'14px'}}}%%
flowchart TD
    %% ─────────────────────────────────────────────
    %% v0.8.0 Data Pipeline — Main Flow
    %% ─────────────────────────────────────────────

    subgraph S1["Stage 1 — Source"]
        PH7["cmc_price_histories7\nRaw OHLCV from CoinMarketCap\n(tick/1m/1h/1D granularity)"]
    end

    subgraph S2["Stage 2 — Bars (6 variants → unified)"]
        BARS["cmc_price_bars_multi_tf_u\nUnified price bars\n(id, ts, tf) primary key\n~4.1M rows, 109 timeframes"]
    end

    subgraph S3["Stage 3 — Returns & EMAs (parallel)"]
        BRET["cmc_returns_bars_multi_tf_u\nBar returns with z-scores\n(ret_arith, ret_log,\n_zscore_30/90/365)"]
        EMAS["cmc_ema_multi_tf_u\nUnified EMA values\n(id, ts, tf, period) PK\n~14.8M rows"]
        ERET["cmc_returns_ema_multi_tf_u\nEMA returns with z-scores\n(d1, d2, d1_roll, d2_roll)"]
    end

    subgraph S4["Stage 4 — Feature Store"]
        VOL["cmc_vol\nVolatility features\n(Parkinson, GK,\nRogers-Satchell, ATR)"]
        TA["cmc_ta\nTechnical indicators\n(RSI-14, MACD, Bollinger,\nATR-14, ADX)"]
        FEAT["cmc_features\n112-column bar-level\nfeature store\n(id, ts, tf) primary key"]
    end

    subgraph S5["Stage 5 — Regime Classification"]
        REG["cmc_regimes\nL0/L1/L2 regime labels\n+ policy resolution\n(HysteresisTracker)"]
        RFLIP["cmc_regime_flips\nRegime transition audit\ntable (old → new)"]
        RSTAT["cmc_regime_stats\nPer-regime return stats\n(avg_ret, std_ret, n_bars)"]
        RCOM["cmc_regime_comovement\nCross-asset regime\nalignment snapshots"]
    end

    subgraph S6["Stage 6 — Signal Generation"]
        SEMA["cmc_signals_ema_crossover\nEMA crossover signals\n(reads cmc_features +\ncmc_ema_multi_tf_u)"]
        SRSI["cmc_signals_rsi_mean_revert\nRSI mean-reversion\nsignals"]
        SATR["cmc_signals_atr_breakout\nATR breakout signals\n(size_mult, stop_mult\nfrom regimes)"]
    end

    subgraph S7["Stage 7 — Backtesting"]
        BRUN["cmc_backtest_runs\nRun metadata\n(strategy, params,\ndate range, commit hash)"]
        BTRD["cmc_backtest_trades\nIndividual trade records\n(entry/exit ts, pnl,\nfees, regime_key)"]
        BMET["cmc_backtest_metrics\nAggregate metrics\n(Sharpe, drawdown,\nwin rate, CAGR)"]
    end

    subgraph S8["Stage 8 — Stats / QA"]
        BSTAT["cmc_bar_stats\nBar data quality\nchecks (6 runners)"]
        FSTAT["cmc_features_stats\nFeature distribution\nand outlier stats"]
        AUD["audit_results\nPipeline audit trail\n(row counts, freshness,\ncoverage checks)"]
    end

    %% ─────────────────────────────────────────────
    %% Data flow edges
    %% ─────────────────────────────────────────────

    PH7 --> BARS

    BARS --> BRET
    BARS --> EMAS
    BARS --> VOL
    BARS --> TA

    EMAS --> ERET
    EMAS --> FEAT

    BRET --> FEAT
    VOL --> FEAT
    TA --> FEAT

    FEAT --> REG
    FEAT --> SEMA
    FEAT --> SRSI
    FEAT --> SATR

    EMAS -.->|"LEFT JOIN for EMA\nperiod data"| SEMA

    REG --> RFLIP
    REG --> RSTAT
    REG --> RCOM
    REG -.->|"regime_key\n(optional)"| SATR

    SEMA --> BRUN
    SRSI --> BRUN
    SATR --> BRUN
    BRUN --> BTRD
    BRUN --> BMET

    BARS --> BSTAT
    FEAT --> FSTAT
    BRUN --> AUD
    BTRD --> AUD

